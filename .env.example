# ── Frontend (Vite) ──────────────────────────────────────────
# URL to the backend server (leave empty to use Vite proxy in dev)
VITE_API_URL=

# ── Backend (server/.env) ───────────────────────────────────
# Optional: set a server-side Gemini key so users don't need to enter their own
# If not set, users provide their own key in the app UI
GEMINI_API_KEY=

# Origin allowed by CORS (your frontend URL in production)
FRONTEND_URL=http://localhost:5173

# Server port
PORT=3001
